{
  "cli": {
    "version": ">= 18.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "autoIncrement": true,
      "developmentClient": true,
      "distribution": "internal"
    },
    "ios-simulator": {
      "extends": "preview",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "environment": "preview",
      "autoIncrement": true,
      "distribution": "internal"
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "environment": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
